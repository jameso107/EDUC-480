# Optional: enables the live ethical learning chatbot (OpenAI-compatible API)
OPENAI_API_KEY=
# Optional override (default: https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1
# Optional model id (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Post-survey → Formspree (https://formspree.io). Defaults to the project form
# https://formspree.io/f/meevqvzy if unset. Override with either:
# SURVEY_FORMSPREE_ID=meevqvzy
# SURVEY_FORM_ACTION=https://formspree.io/f/otherid
# SURVEY_FORMSPREE_ID=
# SURVEY_FORM_ACTION=
