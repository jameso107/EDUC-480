# Optional: enables the live ethical learning chatbot (OpenAI-compatible API)
OPENAI_API_KEY=
# Optional override (default: https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1
# Optional model id (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Post-survey submits in the browser to Formspree. Default form URL is set in
# lib/survey-form-endpoint.ts (meevqvzy). To use a different form, change that
# constant or add a small NEXT_PUBLIC env + code change—no server env required.
